# General Settings
desktop-notifications = true
link-url = true
fullscreen = false
initial-window = true
confirm-close-surface = false
quit-after-last-window-closed = false
vt-kam-allowed = false
shell-integration = detect
shell-integration-features = cursor,no-sudo
osc-color-report-format = 16-bit
term = xterm-ghostty

# Clipboard Settings
clipboard-read = allow
clipboard-write = allow
copy-on-select = false
clipboard-trim-trailing-spaces = true
clipboard-paste-protection = true
clipboard-paste-bracketed-safe = true

# Appearance Settings
theme = Catppuccin Mocha
bold-is-bright = false
background-opacity = 0.90
background-blur-radius = 60
cursor-style = bar
cursor-style-blink = false
window-padding-x = 10
window-padding-y = 8
window-padding-color = extend-always

# Font Settings
font-family = Cartograph CF
window-title-font-family = "0xProto Nerd Font Mono"
font-style = default
font-style-bold = default
font-style-italic = default
font-style-bold-italic = "Cartograph CF Bold Italic"
font-synthetic-style = bold,italic,bold-italic
font-size = 12
font-thicken = true
grapheme-width-method = unicode

# Mouse Settings
mouse-hide-while-typing = true
mouse-shift-capture = true
focus-follows-mouse = true

# Scrollback & Storage
scrollback-limit = 10000000
image-storage-limit = 320000000
click-repeat-interval = 0

# GTK Settings
gtk-tabs-location = bottom
gtk-wide-tabs = false
# gtk-adwaita = false
gtk-titlebar = false

# Unbind alt+Number keys to allow them to be passed through to tmux
keybind = alt+1=unbind
keybind = alt+2=unbind
keybind = alt+3=unbind
keybind = alt+4=unbind
keybind = alt+5=unbind
keybind = alt+6=unbind
keybind = alt+7=unbind
keybind = alt+8=unbind
keybind = alt+9=unbind
