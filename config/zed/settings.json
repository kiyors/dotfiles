// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "diff_view_style": "unified",
  "agent_servers": {
    "opencode": {
      "type": "registry"
    },
    "gemini": {
      "type": "registry"
    }
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "agent": {
    "dock": "left",
    "favorite_models": [],
    "model_parameters": [],
  },
  "git_panel": {
    "dock": "right",
  },
  "project_panel": {
    "dock": "right",
  },
  "vim_mode": true,
  "icon_theme": "Catppuccin Mocha",
  "ui_font_size": 16,
  "buffer_font_size": 14,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Catppuccin Frappé",
  },
  "auto_install_extensions": {
    "biome": true,
    "catppuccin-icons": true,
    "dockerfile": true,
    "git-firefly": true,
    "go-snippets": true,
    "html": true,
    "html-snippets": true,
    "lua": true,
    "nextjs-react-snippets": true,
    "nix": true,
    "prisma": true,
    "react-snippets": true,
    "react-typescript-snippets": true,
    "rust-snippets": true,
    "sql": true,
    "terraform": true,
    "toml": true,
    "zig": true,
  },
  "languages": {
    "Nix": {
      "language_servers": ["nixd", "!nil"],
    },
  },
}
