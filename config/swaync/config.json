{
  "$schema": "/run/current-system/sw/share/swaync/configSchema.json",
  "control-center-layer": "top",
  "control-center-width": 400,
  "control-center-height": 400,
  "control-center-margin-top": 10,
  "control-center-margin-bottom": 250,
  "control-center-margin-right": 10,
  "notification-window-width": 380,
  "notification-icon-size": 48,
  "notification-body-image-height": 80,
  "notification-body-image-width": 160,
  "notification-2fa-action": true,
  "notification-grouping": false,
  "image-visibility": "when-available",
  "transition-time": 100,
  "widgets": [
    "title",
    "buttons-grid",
    "dnd",
    "inhibitors",
    "mpris",
    "notifications"
  ],
  "widget-config": {
    "inhibitors": {
      "text": "Inhibitors",
      "button-text": "Clear All",
      "clear-all-button": true
    },
    "title": {
      "text": "Notifications",
      "clear-all-button": true,
      "button-text": "Clear All"
    },
    "dnd": {
      "text": "Do Not Disturb"
    },
    "mpris": {
      "image-size": 64,
      "blur": true
    },
    "buttons-grid": {
      "actions": [
        {
          "label": "󰐥",
          "command": "systemctl poweroff"
        },
        {
          "label": "󰜉",
          "command": "systemctl reboot"
        },
        {
          "label": "󰒲",
          "command": "systemctl suspend"
        },
        {
          "label": "󰌾",
          "command": "hyprlock"
        },
        {
          "label": "󰍃",
          "command": "hyprctl dispatch exit"
        },
        {
          "label": "󰕾",
          "command": "swayosd-client --output-volume mute-toggle"
        },
        {
          "label": "󰍬",
          "command": "swayosd-client --input-volume mute-toggle"
        },
        {
          "label": "󰂯",
          "command": "blueman-manager"
        },
        {
          "label": "󰹑",
          "command": "hyprshot -m region"
        },
        {
          "label": "",
          "command": "kooha"
        },
        {
          "label": "",
          "command": "caffeine"
        },
        {
          "label": "󰋱",
          "command": "hyprfocus-toggle"
        }
      ]
    }
  }
}
